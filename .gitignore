# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Node / Vite / Svelte
node_modules/
ui/dist/
*.tsbuildinfo

# Rust / Tauri
src-tauri/target/
# Tauri build-generated capability/ACL schemas (regenerated each build)
src-tauri/gen/schemas/
# Frozen PyInstaller backend sidecar (multi-GB build artifact, never committed)
src-tauri/binaries/

# TalkTeach local data (projects, audio, models — never committed)
.talkteach/
*.db
*.db-wal
*.db-shm

# Benchmark outputs + downloaded TTS voices / model caches (never committed)
*.results.json
benchmarks/results/
piper_voices/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Personal Claude Code overrides (e.g. statusline console) — machine-specific, never shared
.claude/settings.local.json

# Secrets & signing material — NEVER commit. These live ONLY in GitHub Actions
# encrypted secrets (see project/docs/RELEASING.md). The patterns below are a
# safety net; the `detect-private-key` pre-commit hook is the second line.
.env
.env.*
!.env.example
secrets/
.tauri/
*.p12
*.pfx
*.pem
*.key
*.cer
*.crt
*.der
*.p8
*.jks
*.keystore
*.mobileprovision
*.asc
.prepush-logs/
.harness/state/
.worktrees/
